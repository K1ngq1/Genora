DATABASE_URL="file:./dev.db"
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_AGNES_BUCKET="agnes-inputs"

# Transactional email via SMTP for the self-hosted signup OTP. Server-only.
# Works with QQ Mail (smtp.qq.com:465), 163, Gmail, Tencent EXMail, etc.
# QQ Mail: Settings → Account → enable SMTP/IMAP → generate an authorization
# code (授权码, NOT your QQ login password) and use it as SMTP_PASS.
SMTP_HOST="smtp.qq.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Genora <your@qq.com>"
OPENAI_API_KEY=""
# Agnes per-service API keys (need generation permission, not the read-only account key).
AGNES_1_5_FLASH_API_KEY=""
AGNES_IMAGE_2_1_FLASH_API_KEY=""
AGNES_VIDEO_V2_0_API_KEY=""

# APIMart server-only keys. Never expose these with NEXT_PUBLIC_.
APIMART_KEY_IMAGE=""
APIMART_KEY_VIDEO=""
APIMART_KEY_DEV=""
APIMART_PROXY_URL=""
